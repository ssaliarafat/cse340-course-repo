<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <p class="org-p"><b>Here are a few of our partner organizations:</b></p>
        <br>

        <ul>
        
            <% organizations.forEach(organization=> { %>
                <li><img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo"><strong>
                        <%= organization.name %>
                    </strong>: <%= organization.contact_email %>
                </li>
                <% }); %>
        </ul>

    </main>

    <%- include('partials/footer') %>